{
  "name": "@genius-x/server",
  "version": "0.0.0",
  "private": true,
  "description": "Course engine (stage state machine) + WebSocket classroom sync + API. Calls AI only through @genius-x/ai-gateway.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:seed": "tsx scripts/migrate.ts --seed"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@genius-x/ai-gateway": "workspace:*",
    "@genius-x/config": "workspace:*",
    "@genius-x/contracts": "workspace:*",
    "@genius-x/course-config": "workspace:*",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.0",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  }
}
