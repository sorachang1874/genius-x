# Genius X — environment template. Copy to .env (git-ignored) and fill in.
# NEVER commit real keys. Keys live server-side only — never shipped to the web client.

# Runtime mode: local | scripted | live | production
GENIUS_X_MODE=local

# --- AI providers (filled per chosen provider; routed only via @genius-x/ai-gateway) ---
# LLM_API_KEY=
# TTS_API_KEY=
# ASR_API_KEY=
# IMAGE_GEN_API_KEY=

# --- Datastores (PRD §3) ---
# DATABASE_URL=postgres://...
# REDIS_URL=redis://...

# --- Tencent Cloud (deploy / COS storage) ---
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# COS_BUCKET=
